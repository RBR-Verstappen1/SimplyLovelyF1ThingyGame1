  // ----- Barrier drawing (metal wall + LED + curbs) -----
  function drawBarriers() {
    const trackWidth = 70, offset = trackWidth / 2 + 8, wallThickness = 14;
    for (let i = 0; i < trackPoints.length; i++) {
      let p = trackPoints[i], next = trackPoints[(i + 1) % trackPoints.length];
      let dx = next.x - p.x, dy = next.y - p.y, len = Math.hypot(dx, dy);
      if (len === 0) continue;
      let nx = -dy / len, ny = dx / len;
      let leftX = p.x + nx * offset, leftY = p.y + ny * offset;
      let rightX = p.x - nx * offset, rightY = p.y - ny * offset;

      ctx.save();
      ctx.shadowColor = '#000'; ctx.shadowBlur = 8;
      ctx.beginPath(); ctx.moveTo(leftX, leftY); ctx.lineTo(leftX + dx, leftY + dy); ctx.lineWidth = wallThickness;
      const gradLeft = ctx.createLinearGradient(leftX, leftY, leftX + dx, leftY + dy);
      gradLeft.addColorStop(0, '#2a2a2a'); gradLeft.addColorStop(0.5, '#4a4a4a'); gradLeft.addColorStop(1, '#1a1a1a');
      ctx.strokeStyle = gradLeft; ctx.stroke();
      ctx.beginPath(); ctx.moveTo(rightX, rightY); ctx.lineTo(rightX + dx, rightY + dy);
      const gradRight = ctx.createLinearGradient(rightX, rightY, rightX + dx, rightY + dy);
      gradRight.addColorStop(0, '#2a2a2a'); gradRight.addColorStop(0.5, '#4a4a4a'); gradRight.addColorStop(1, '#1a1a1a');
      ctx.strokeStyle = gradRight; ctx.stroke();
      ctx.shadowBlur = 0; ctx.restore();

      ctx.beginPath(); ctx.moveTo(leftX, leftY); ctx.lineTo(leftX + dx, leftY + dy); ctx.lineWidth = 4; ctx.strokeStyle = '#E10600'; ctx.shadowBlur = 10; ctx.shadowColor = '#ff0000'; ctx.stroke();
      ctx.beginPath(); ctx.moveTo(rightX, rightY); ctx.lineTo(rightX + dx, rightY + dy); ctx.stroke(); ctx.shadowBlur = 0;

      for (let s = 0; s < len; s += 22) {
        let t = s / len, x = p.x + dx * t, y = p.y + dy * t;
        let stripeColor = (Math.floor(s / 22) % 2 === 0) ? '#E10600' : '#FFFFFF';
        ctx.fillStyle = stripeColor;
        ctx.fillRect(leftX - 4, leftY - 4, 8, 8);
        ctx.fillRect(rightX - 4, rightY - 4, 8, 8);
        leftX += dx * 22 / len; leftY += dy * 22 / len;
        rightX += dx * 22 / len; rightY += dy * 22 / len;
      }
    }
  }

  // ----- Main race loop (includes manual control) -----
  function raceLoop(ts) {
    if (!raceActive) return;
    if (racePaused) { drawScene(); animationFrame = requestAnimationFrame(raceLoop); return; }
    if (!raceStarted) { drawScene(); lastTimestamp = ts; animationFrame = requestAnimationFrame(raceLoop); return; }
    if (!lastTimestamp) lastTimestamp = ts;
    const delta = Math.min(50, ts - lastTimestamp);
    if (delta > 5) {
      // Manual driving for player car
      let playerCar = cars.find(c => c.manual);
      if (playerCar && controller.active) {
        let targetSpeed = playerCar.topSpeed * Math.max(0, controller.throttle);
        if (controller.brake) targetSpeed = 0;
        playerCar.currentSpeed += (targetSpeed - playerCar.currentSpeed) * 0.1 * (delta / 16);
        playerCar.currentSpeed = Math.max(0, Math.min(playerCar.topSpeed, playerCar.currentSpeed));
        if (playerCar.currentSpeed > 0.5) {
          playerCar.angle += controller.steering * 0.04 * (delta / 16);
        }
        playerCar.vx = Math.cos(playerCar.angle) * playerCar.currentSpeed;
        playerCar.vy = Math.sin(playerCar.angle) * playerCar.currentSpeed;
        playerCar.x += playerCar.vx * (delta / 16);
        playerCar.y += playerCar.vy * (delta / 16);
        
        // Engine sound: adjust pitch based on speed (simulate RPM)
        if (audio.engineSource) {
          let pitch = 0.8 + (playerCar.currentSpeed / playerCar.topSpeed) * 0.7;
          audio.engineSource.playbackRate.value = pitch;
        }
      }

      // Update all cars (AI and non‑manual player cars)
      for (let car of cars) {
        if (car.is_finished) continue;
        if (!car.manual) {
          let pos = findClosestTrackPoint(car.x, car.y);
          let dir = getDirectionAt(pos.idx);
          let target = car.topSpeed + car.slipstream;
          car.currentSpeed = Math.min(target, car.currentSpeed + (target - car.currentSpeed) * 0.05 * (delta / 16));
          car.x += dir.x * car.currentSpeed * (delta / 16);
          car.y += dir.y * car.currentSpeed * (delta / 16);
        }

        let newPos = findClosestTrackPoint(car.x, car.y);
        let newRawDist = getDistanceAtPoint(newPos.idx);
        let oldRawDist = car.rawDist;

        // Lap crossing detection – only increments when hasCrossedStart is false AND crossing start line
        if (!car.hasCrossedStart && oldRawDist > trackLength * 0.8 && newRawDist < trackLength * 0.2) {
          car.lap++;
          car.hasCrossedStart = true;
          if (car.lap > MAX_LAPS) car.is_finished = true;
        } else if (car.hasCrossedStart && oldRawDist < trackLength * 0.2 && newRawDist > trackLength * 0.8) {
          car.hasCrossedStart = false;
        }

        car.rawDist = newRawDist;
        car.totalDistance = (car.lap - 1) * trackLength + car.rawDist;

        // Keep on track
        let wasOffTrack = (newPos.dist > 38);
        if (wasOffTrack) {
          car.currentSpeed *= 0.45;
          car.x += (trackPoints[newPos.idx].x - car.x) * 0.25;
          car.y += (trackPoints[newPos.idx].y - car.y) * 0.25;
          // Wall scrape / off-track sound (player only, with cooldown to avoid spam)
          if (car.isPlayer && !car.collisionCooldown) {
            audio.playSound('scrape');
            car.collisionCooldown = true;
            setTimeout(() => car.collisionCooldown = false, 500);
          }
        }
        if (newPos.dist > 57) {
          car.x = trackPoints[newPos.idx].x;
          car.y = trackPoints[newPos.idx].y;
          car.currentSpeed *= 0.3;
        }

        if (!car.manual && car.currentSpeed > 0.1) {
          let dir = getDirectionAt(findClosestTrackPoint(car.x, car.y).idx);
          let targetAngle = Math.atan2(dir.y, dir.x);
          let diff = targetAngle - car.angle;
          while (diff > Math.PI) diff -= 2 * Math.PI;
          while (diff < -Math.PI) diff += 2 * Math.PI;
          car.angle += diff * 0.15;
        }
        if (!car.manual) {
          car.vx = Math.cos(car.angle) * car.currentSpeed;
          car.vy = Math.sin(car.angle) * car.currentSpeed;
        }

        // Slipstream
        car.slipstream = 0;
        for (let other of cars) {
          if (other === car || other.is_finished) continue;
          let d = Math.hypot(car.x - other.x, car.y - other.y);
          if (d < 60 && d > 5) {
            let dot = (car.vx * other.vx + car.vy * other.vy) / (car.currentSpeed * other.currentSpeed || 1);
            if (dot > 0.7) { car.slipstream = 0.18; break; }
          }
        }
      }
      updateLeaderboard();
      updateCyberLeaderboard();
      checkRaceFinish();
    }
    drawScene();
    lastTimestamp = ts;
    animationFrame = requestAnimationFrame(raceLoop);
  }

  function updateLeaderboard() {
    let sorted = [...cars].sort((a, b) => {
      if (a.is_finished !== b.is_finished) return b.is_finished - a.is_finished;
      return b.totalDistance - a.totalDistance;
    });
    sorted.forEach((c, i) => c.position = i + 1);
    let player = cars.find(c => c.isPlayer);
    if (player) {
      getEl('hud-lap').innerText = player.is_finished ? MAX_LAPS : player.lap;
      getEl('hud-pos').innerText = player.position;
    }
  }

