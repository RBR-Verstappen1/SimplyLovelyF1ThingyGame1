if (StoryState.currentScene === 'CREDITS' || StoryState.showGallery) {
if (e.code === 'KeyG') {
StoryState.showGallery = !StoryState.showGallery;
if (StoryState.showGallery) {
document.getElementById('sceneLabel').innerText = '🖼️ GALLERY · LORE & MODELS 🖼️';
} else {
document.getElementById('sceneLabel').innerText = '🎬 CREDITS · REBELLION\'S END 🎬';
}
e.preventDefault();
return;
}
if (e.code === 'KeyR') {
window.location.reload();
e.preventDefault();
return;
}
if (StoryState.showGallery) {
if (e.code === 'ArrowLeft') {
StoryState.galleryIndex = (StoryState.galleryIndex - 1 + galleryItems.length) % galleryItems.length;
e.preventDefault();
} else if (e.code === 'ArrowRight') {
StoryState.galleryIndex = (StoryState.galleryIndex + 1) % galleryItems.length;
e.preventDefault();
} else if (e.code === 'Escape') {
StoryState.showGallery = false;
document.getElementById('sceneLabel').innerText = '🎬 CREDITS · REBELLION\'S END 🎬';
e.preventDefault();
}
return;
}
if (e.code === 'Space') {
// Skip credits
StoryState.creditsY = -1000;
e.preventDefault();
return;
}
}
originalKeyDown(e);
};

