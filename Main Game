  function hireDriver(id){
    playClickSound();
    if(STATE.myDrivers.length >= 2) return;
    const d = MARKET_DRIVERS.find(x => x.id === id);
    if(!d) return;
    if(STATE.myDrivers.filter(m => m.team === d.team).length >= 2) return;
    if(STATE.money < d.cost) return;
    STATE.money -= d.cost;
    STATE.myDrivers.push(d);
    updateMoney();
    renderMarket();
    audio.playSound('click'); // extra confirmation sound
  }

  function fireDriver(id){
    playClickSound();
    const d = STATE.myDrivers.find(x => x.id === id);
    if(!d) return;
    if(d.cost > 0) STATE.money += Math.floor(d.cost / 2);
    STATE.myDrivers = STATE.myDrivers.filter(x => x.id !== id);
    updateMoney();
    renderMarket();
  }

  function hireSecretDriver(id){
    playClickSound();
    if(!STATE.unlockedSecrets) return;
    const d = SECRET_DRIVERS.find(x => x.id === id);
