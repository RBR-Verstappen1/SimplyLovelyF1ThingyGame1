function generateTrackWaypoints(geo){ const c=geoToGame(geo.lon,geo.lat); const seed=(geo.lon*1000+geo.lat*1000)%100; const count=8+Math.floor(seed%5); const r=2.5+(seed%2)*0.8; const pts=[]; for(let i=0;i<count;i++){ const a=(i/count)*Math.PI*2; const ox=Math.cos(a)*r*(1+0.3*Math.sin(a*2+seed)); const oy=Math.sin(a)*r*(1+0.2*Math.cos(a*3+seed)); pts.push({x:c.x+ox*800,y:c.y+oy*800}); } return pts; }
const CALENDAR = TRACK_GEO.map(t=>{ const raw=generateTrackWaypoints(t); const xs=raw.map(p=>p.x),ys=raw.map(p=>p.y); const minX=Math.min(...xs),maxX=Math.max(...xs),minY=Math.min(...ys),maxY=Math.max(...ys); const scale=5/Math.max(maxX-minX,maxY-minY,1); const wp=raw.map(p=>[(p.x-minX)*scale,(p.y-minY)*scale]); return{n:t.name,c:t.location,wp,id:t.id}; });

