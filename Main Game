function pushDialogue(speaker, text, callback) {
StoryState.dialogueQueue.push({ speaker, text, callback });
if (!StoryState.activeDialogue) nextDialogue();
}
function nextDialogue() {
if (StoryState.dialogueQueue.length === 0) {
StoryState.activeDialogue = null;
dialogueBox.style.display = 'none';
handleSceneProgression();
return;
}
StoryState.activeDialogue = StoryState.dialogueQueue.shift();
StoryState.typewriterIndex = 0;
StoryState.waitForInput = false;
dialogueBox.style.display = 'block';
}
function advanceDialogue() {
if (StoryState.activeDialogue?.callback) StoryState.activeDialogue.callback();
nextDialogue();
}

function handleSceneProgression() {
const s = StoryState.currentScene;
if (s === 'HALL') {
if (StoryState.playerPos.y < 180 && !StoryState.portalTriggered) {
StoryState.portalTriggered = true;
StoryState.currentScene = 'PORTAL';
startPortalEvent();
}
