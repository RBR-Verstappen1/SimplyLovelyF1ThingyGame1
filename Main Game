  // ----- CONTROLLER CLASS (for manual driving) -----
  class Controller {
    constructor(){
      this.throttle = 0;      // -1 (reverse) to 1 (full throttle)
      this.steering = 0;      // -1 (left) to 1 (right)
      this.brake = false;     // true = full brake
      this.active = false;
      this.touchMode = false;
      this.joystickActive = false;
      this.joystickId = null;
      this.joystickStart = {x:0, y:0};
      this.setupListeners();
    }
    setupListeners(){
      // Keyboard
      window.addEventListener('keydown', e => {
        if(!this.active || STATE.weekend.mode !== 'driving') return;
        switch(e.code){
          case 'KeyW': this.throttle = 1; e.preventDefault(); break;
          case 'KeyS': this.throttle = -0.5; e.preventDefault(); break;
          case 'KeyA': this.steering = -1; e.preventDefault(); break;
          case 'KeyD': this.steering = 1; e.preventDefault(); break;
          case 'Space': this.brake = true; e.preventDefault(); break;
        }
      });
      window.addEventListener('keyup', e => {
        if(!this.active || STATE.weekend.mode !== 'driving') return;
        switch(e.code){
          case 'KeyW': if(this.throttle > 0) this.throttle = 0; e.preventDefault(); break;
          case 'KeyS': if(this.throttle < 0) this.throttle = 0; e.preventDefault(); break;
          case 'KeyA': if(this.steering < 0) this.steering = 0; e.preventDefault(); break;
          case 'KeyD': if(this.steering > 0) this.steering = 0; e.preventDefault(); break;
          case 'Space': this.brake = false; e.preventDefault(); break;
        }
      });
      // Neumorphic Joystick
      const jContainer = getEl('joystick-container');
      const jThumb = getEl('joystick-thumb');
      const brakeBtn = getEl('brake-btn');
      
      const startJoystick = (e) => {
        if(!this.active || STATE.weekend.mode !== 'driving') return;
        e.preventDefault();
        this.touchMode = true;
        this.joystickActive = true;
        this.joystickId = e.pointerId;
        const rect = jContainer.getBoundingClientRect();
        this.joystickStart = {x: rect.left + rect.width/2, y: rect.top + rect.height/2};
        jContainer.classList.add('active');
        this.updateJoystick(e.clientX, e.clientY);
        jContainer.setPointerCapture(e.pointerId);
      };
      
      const moveJoystick = (e) => {
        if(!this.active || !this.joystickActive || e.pointerId !== this.joystickId) return;
        e.preventDefault();
        this.updateJoystick(e.clientX, e.clientY);
      };
      
      const endJoystick = (e) => {
        if(e.pointerId === this.joystickId){
          this.joystickActive = false;
          this.joystickId = null;
          this.steering = 0;
          this.throttle = 0;
          jThumb.style.transform = `translate(-50%, -50%)`;
          jContainer.classList.remove('active');
        }
      };
      
      jContainer.addEventListener('pointerdown', startJoystick);
      jContainer.addEventListener('pointermove', moveJoystick);
      jContainer.addEventListener('pointerup', endJoystick);
      jContainer.addEventListener('pointercancel', endJoystick);
      
      brakeBtn.addEventListener('pointerdown', e => {
        if(!this.active) return;
        this.brake = true;
        brakeBtn.classList.add('active');
        e.preventDefault();
      });
      brakeBtn.addEventListener('pointerup', e => {
        this.brake = false;
        brakeBtn.classList.remove('active');
        e.preventDefault();
      });
      brakeBtn.addEventListener('pointerleave', () => {
        this.brake = false;
        brakeBtn.classList.remove('active');
      });
    }
    updateJoystick(clientX, clientY){
      const jThumb = getEl('joystick-thumb');
      const maxDist = 45; // matches joystick radius
      let dx = clientX - this.joystickStart.x;
      let dy = clientY - this.joystickStart.y;
      const dist = Math.min(Math.hypot(dx, dy), maxDist);
      const angle = Math.atan2(dy, dx);
      const limitedX = Math.cos(angle) * dist;
      const limitedY = Math.sin(angle) * dist;
      jThumb.style.transform = `translate(calc(-50% + ${limitedX}px), calc(-50% + ${limitedY}px))`;
      // Steering: horizontal component (-1 to 1)
      this.steering = Math.max(-1, Math.min(1, dx / maxDist));
      // Throttle: vertical component (up = negative Y = accelerate, down = positive Y = reverse)
      this.throttle = Math.max(-1, Math.min(1, -dy / maxDist));
    }
    activate(){ this.active = true; this.touchMode = false; }
    deactivate(){ this.active = false; this.throttle = 0; this.steering = 0; this.brake = false; }
  }
  controller = new Controller();

  // ----- TRACK GENERATION HELPERS -----
  function catmullRom(p0, p1, p2, p3, t){
    const v0 = {x: (p2.x-p0.x)*0.5, y: (p2.y-p0.y)*0.5};
    const v1 = {x: (p3.x-p1.x)*0.5, y: (p3.y-p1.y)*0.5};
    const t2 = t*t, t3 = t2*t;
    return {
      x: (2*p1.x-2*p2.x+v0.x+v1.x)*t3 + (-3*p1.x+3*p2.x-2*v0.x-v1.x)*t2 + v0.x*t + p1.x,
      y: (2*p1.y-2*p2.y+v0.y+v1.y)*t3 + (-3*p1.y+3*p2.y-2*v0.y-v1.y)*t2 + v0.y*t + p1.y
    };
  }
  function generateTrack(rawWp, seg = 200){
    let pts = [];
    for(let i=0; i<rawWp.length; i++){
      let p0 = rawWp[(i-1+rawWp.length)%rawWp.length];
      let p1 = rawWp[i];
      let p2 = rawWp[(i+1)%rawWp.length];
      let p3 = rawWp[(i+2)%rawWp.length];
      for(let t=0; t<1; t+=1/seg) pts.push(catmullRom(p0, p1, p2, p3, t));
    }
    return pts;
  }
  function computeTangents(){
    trackTangents = [];
    for(let i=0; i<trackPoints.length; i++){
      let prev = trackPoints[(i-1+trackPoints.length)%trackPoints.length];
      let next = trackPoints[(i+1)%trackPoints.length];
      let dx = next.x - prev.x, dy = next.y - prev.y;
      let len = Math.hypot(dx, dy);
      trackTangents.push({x: dx/len, y: dy/len});
    }
  }
  function computeLength(){
    let len = 0;
    for(let i=1; i<trackPoints.length; i++) len += Math.hypot(trackPoints[i].x-trackPoints[i-1].x, trackPoints[i].y-trackPoints[i-1].y);
    return len + Math.hypot(trackPoints[0].x-trackPoints[trackPoints.length-1].x, trackPoints[0].y-trackPoints[trackPoints.length-1].y);
  }
  function findClosestTrackPoint(x, y){
    let best = 0, bestDist = Infinity;
    for(let i=0; i<trackPoints.length; i++){
      let dx = x - trackPoints[i].x, dy = y - trackPoints[i].y;
      let d = dx*dx + dy*dy;
      if(d < bestDist){ bestDist = d; best = i; }
    }
    return {idx: best, dist: Math.sqrt(bestDist)};
  }
  function getDirectionAt(i){ return trackTangents[i % trackPoints.length]; }
  function getDistanceAtPoint(idx){
    let d = 0;
    for(let j=1; j<=idx; j++) d += Math.hypot(trackPoints[j].x-trackPoints[j-1].x, trackPoints[j].y-trackPoints[j-1].y);
    return d;
  }

