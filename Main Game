  function generateWeather(){
    const types = ["Sunny","Overcast","Rain","Heavy Rain"];
    const degs = ["Low","Medium","High","Critical"];
    let type = types[Math.floor(Math.random()*types.length)];
    let deg = degs[Math.floor(Math.random()*degs.length)];
    let temp = Math.floor(Math.random()*25)+12;
    let wind = Math.floor(Math.random()*45);
    if(type.includes("Rain")) temp -= 10;
    let impact = "Optimal track conditions.";
    if(type === "Rain") impact = "Slippery surface. Grip -20%.";
    else if(type === "Heavy Rain") impact = "Extreme danger. Speed reduced.";
    else if(temp > 32 && deg === "Critical") impact = "Scorching heat. High tire degradation.";
    else if(wind > 30) impact = "Strong crosswinds.";
    STATE.weekend.weather = {type, temp, wind, deg, impact};
    getEl('w-type').innerText = type;
    getEl('w-type').className = `text-2xl font-bold ${type.includes("Rain")?'text-blue-400':'text-yellow-400'}`;
    getEl('w-temp').innerText = temp + "°C";
    getEl('w-wind').innerText = wind + " km/h";
    getEl('w-deg').innerText = deg;
    getEl('w-deg').className = `text-2xl font-bold ${deg==="Critical"||deg==="High"?'text-red-500':'text-green-400'}`;
