<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Formula Football : Verstappen Edition</title>
<script src="https://cdn.tailwindcss.com"></script>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
/* ========== COMPLETE STYLES (WITH LEADERBOARD + BORDER GLOW) ========== */
:root {
--f1-red: #E10600; --f1-dark: #15151E; --f1-darker: #0A0A0E; --f1-light: #F3F3F3;
--neon-blue: #00D2FF; --neon-purple: #B026FF; --glass-bg: rgba(21,21,30,0.7);
--glass-border: rgba(255,255,255,0.08); --ui-scale: 1;
--accent: #00f2ff; --teammate: #c084ff; --gold: #ffd700; --silver: #e0e0e0; --bronze: #ff8c00;
--bg-dark: rgba(8, 8, 16, 0.95); --player-glow: 0 0 12px rgba(0, 242, 255, 0.6);
--teammate-glow: 0 0 10px rgba(192, 132, 255, 0.6);
}
body { margin:0; overflow:hidden; font-family:'Rajdhani',sans-serif; background-color:var(--f1-darker); color:var(--f1-light); user-select:none; touch-action:none; }
.font-orbitron { font-family:'Orbitron',sans-serif; }
.bg-texture { position:absolute; inset:0; background-image:radial-gradient(circle at 15% 50%, rgba(225,6,0,0.08) 0%, transparent 25%), radial-gradient(circle at 85% 30%, rgba(0,210,255,0.05) 0%, transparent 25%); pointer-events:none; z-index:0; }
.menu-bg { background-image:linear-gradient(to right, rgba(10,10,14,0.95) 30%, rgba(10,10,14,0.4)), url('https://4kwallpapers.com/images/walls/thumbs_3t/13972.jpeg'); background-size:cover; background-position:center; }
.f1-panel { background:var(--glass-bg); backdrop-filter:blur(20px); border:1px solid var(--glass-border); box-shadow:0 8px 32px rgba(0,0,0,0.5); border-radius:16px; position:relative; overflow:hidden; }
.f1-panel::before { content:''; position:absolute; top:0; left:0; width:4px; height:100%; background:linear-gradient(to bottom, var(--f1-red), transparent); }
.f1-btn { font-family:'Orbitron',sans-serif; text-transform:uppercase; font-weight:700; letter-spacing:2px; transition:all 0.3s; position:relative; overflow:hidden; z-index:1; }
.f1-btn::before { content:''; position:absolute; top:0; left:-100%; width:100%; height:100%; background:linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); transition:left 0.5s; z-index:-1; }
.f1-btn:hover::before { left:100%; }
.f1-btn:hover { transform:translateY(-2px); box-shadow:0 10px 20px rgba(0,0,0,0.4); }
.f1-btn:active { transform:translateY(1px); }
.f1-btn-primary { background:var(--f1-red); color:white; border:1px solid #ff3333; clip-path:polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px); }
.f1-btn-secondary { background:transparent; color:white; border:1px solid rgba(255,255,255,0.3); }
.f1-btn-secondary:hover { border-color:white; background:rgba(255,255,255,0.1); }
.f1-btn-disabled { opacity:0.4; pointer-events:none; filter:grayscale(100%); }
#sidebar { width:280px; background:rgba(10,10,14,0.98); border-right:1px solid var(--glass-border); display:flex; flex-direction:column; z-index:50; box-shadow:5px 0 20px rgba(0,0,0,0.5); transform:translateX(-100%); transition:transform 0.4s; position:absolute; height:100vh; }
#sidebar.open { transform:translateX(0); }
.nav-item { padding:20px 30px; font-family:'Orbitron'; font-size:1.1rem; color:rgba(255,255,255,0.5); border-left:4px solid transparent; cursor:pointer; transition:all 0.2s; display:flex; align-items:center; gap:15px; }
.nav-item:hover, .nav-item.active { color:white; background:linear-gradient(90deg, rgba(225,6,0,0.1) 0%, transparent 100%); border-left-color:var(--f1-red); }
.driver-card { background:linear-gradient(160deg, #1E1E28 0%, #12121A 100%); border:1px solid #2A2A35; border-radius:12px; transition:all 0.3s; position:relative; overflow:hidden; clip-path:polygon(15px 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%, 0 15px); }
.driver-card:hover { transform:translateY(-5px) scale(1.02); border-color:var(--f1-red); box-shadow:0 15px 30px rgba(225,6,0,0.15); }
.driver-img-wrapper { height:180px; display:flex; justify-content:center; align-items:flex-end; background:radial-gradient(circle at center, #2A2A35 0%, #000 100%); border-bottom:2px solid #333; }
.driver-img { height:95%; object-fit:contain; filter:drop-shadow(0 10px 10px rgba(0,0,0,0.5)); transition:transform 0.3s; background:#000; }
.driver-card:hover .driver-img { transform:scale(1.08); }
.stat-bar { height:4px; background:#333; border-radius:2px; overflow:hidden; margin-top:4px; }
.stat-fill { height:100%; background:var(--neon-blue); }
.secret-card { border-color:var(--neon-purple); background:linear-gradient(160deg, #2a113d 0%, #0d0414 100%); }
.secret-card .stat-fill { background:var(--neon-purple); }
.secret-blacked-out { filter: brightness(0) invert(0); opacity:0.5; }
.track-card { background:var(--glass-bg); border:1px solid var(--glass-border); border-radius:12px; padding:20px; cursor:pointer; transition:all 0.2s; position:relative; overflow:hidden; }
.track-card:hover { border-color:white; background:rgba(30,30,40,0.9); transform:scale(1.03); }
.track-num { position:absolute; top:-10px; right:-10px; font-size:80px; font-family:'Orbitron'; font-weight:900; color:rgba(255,255,255,0.03); }
#secret-btn { position:fixed; bottom:20px; right:20px; font-size:12px; opacity:0.4; padding:8px 12px; cursor:pointer; color:#fff; background:rgba(0,0,0,0.5); border:1px solid rgba(255,255,255,0.2); border-radius:20px; z-index:9999; font-family:monospace; backdrop-filter:blur(4px); transition:all 0.3s; animation:pulse 2s infinite; }
@keyframes pulse { 0%{opacity:0.4} 50%{opacity:0.8} 100%{opacity:0.4} }
#secret-btn:hover { opacity:1; background:rgba(225,6,0,0.7); border-color:white; }
#genie-modal { background:rgba(5,0,15,0.95); z-index:10000; backdrop-filter:blur(10px); }
.typewriter-container { font-family:'Courier New',monospace; color:#0f0; text-shadow:0 0 8px rgba(0,255,0,0.6); min-height:3em; font-size:1.2rem; border-left:2px solid #0f0; padding-left:10px; margin-top:20px; }
.blink-cursor::after { content:'|'; animation:blink 1s step-end infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
.screen { position:absolute; inset:0; opacity:0; pointer-events:none; transition:opacity 0.4s; display:flex; flex-direction:column; overflow-y:auto; }
.screen.active { opacity:1; pointer-events:auto; }
#main-content { margin-left:0; flex:1; position:relative; transition:margin-left 0.4s; height:100vh; overflow:hidden; }
body.sidebar-open #main-content { margin-left:280px; }
.top-bar { height:70px; background:rgba(10,10,14,0.8); backdrop-filter:blur(10px); border-bottom:1px solid var(--glass-border); display:flex; justify-content:space-between; align-items:center; padding:0 30px; position:sticky; top:0; z-index:40; }
.back-btn { font-size:24px; cursor:pointer; color:white; margin-left:10px; }
.back-btn:hover { color:var(--f1-red); }
#race-screen { background:#050505; z-index:100; }
canvas { display:block; width:100%; height:100%; position:absolute; top:0; left:0; }
.race-hud { position:absolute; z-index:101; font-family:'Orbitron'; text-shadow:2px 2px 4px rgba(0,0,0,0.8); pointer-events:none; }
.hud-top-left { top:20px; left:20px; }
.hud-top-right { top:20px; right:20px; text-align:right; }
.hud-panel { background:rgba(0,0,0,0.6); border-left:3px solid var(--f1-red); padding:15px 25px; clip-path:polygon(0 0, 100% 0, 95% 100%, 0% 100%); }
.pause-btn { position:absolute; top:20px; right:20px; z-index:102; background:rgba(0,0,0,0.6); border:1px solid rgba(255,255,255,0.3); border-radius:30px; padding:8px 16px; cursor:pointer; }
.dock-container { position:fixed; bottom:20px; left:0; right:0; display:flex; justify-content:center; pointer-events:none; z-index:200; }
.dock-container.top-dock { bottom:auto; top:80px; }
.dock { display:flex; gap:8px; background:rgba(20,20,30,0.8); backdrop-filter:blur(20px); border-radius:32px; padding:6px 16px; border:1px solid rgba(255,255,255,0.15); pointer-events:auto; }
.dock-item { display:flex; flex-direction:column; align-items:center; width:48px; cursor:pointer; border-radius:12px; padding:6px 0; }
.dock-item:hover { transform:scale(1.1); background:rgba(255,255,255,0.1); }
.dock-icon { font-size:24px; }
.dock-label { font-size:10px; font-weight:bold; margin-top:2px; color:white; background:rgba(0,0,0,0.7); padding:2px 6px; border-radius:20px; opacity:0; transition:opacity 0.2s; white-space:nowrap; }
.dock-item:hover .dock-label { opacity:1; }

/* ---------- HOME SCREEN (with Story Mode entrance) ---------- */
.home-title { font-family:'Orbitron',sans-serif; font-size:6rem; font-weight:900; letter-spacing:-3px; text-shadow:0 0 50px rgba(225,6,0,0.9); margin-bottom:2rem; position:relative; z-index:10; text-align:center; line-height:1.1; }
.home-title .main { color:var(--f1-red); }
.home-title .sub { font-size:3rem; display:block; color:white; font-weight:500; letter-spacing:3px; margin-top:-0.5rem; }
.start-btn { font-size:2.5rem !important; padding:1rem 2.5rem !important; font-weight:700; position:relative; z-index:10; box-shadow:0 0 60px rgba(225,6,0,0.7); }
.story-btn { background: linear-gradient(135deg, #c084fc, #f472b6); border: 2px solid #fff; color: white; font-size: 1.5rem; padding: 0.8rem 2rem; margin-left: 1rem; box-shadow: 0 0 30px #c084fc; }

/* ---------- MINI-MAP ---------- */
#mini-map-container { position: absolute; bottom: 20px; left: 20px; width: calc(200px * var(--ui-scale)); height: calc(150px * var(--ui-scale)); background: rgba(0,0,0,0.7); border: 2px solid var(--f1-red); border-radius: 12px; z-index: 105; pointer-events: none; backdrop-filter: blur(4px); box-shadow: 0 0 20px rgba(0,0,0,0.8); }
#mini-map-canvas { width: 100%; height: 100%; display: block; }

/* ---------- NEUMORPHIC JOYSTICK ---------- */
#joystick-container {
position: absolute;
bottom: calc(180px * var(--ui-scale));
left: calc(30px * var(--ui-scale));
width: calc(150px * var(--ui-scale));
height: calc(150px * var(--ui-scale));
background: #e0e5ec;
border-radius: 50%;
box-shadow: 9px 9px 16px #a3b1c6, -9px -9px 16px #ffffff;
opacity: 0.4;
transition: opacity 0.3s ease;
touch-action: none;
z-index: 110;
pointer-events: auto;
display: none;
}
#joystick-container.active { opacity: 1; }
#joystick-thumb {
width: calc(60px * var(--ui-scale));
height: calc(60px * var(--ui-scale));
background: #e0e5ec;
border-radius: 50%;
position: absolute;
top: 50%; left: 50%;
transform: translate(-50%, -50%);
box-shadow: inset 6px 6px 12px #a3b1c6, inset -6px -6px 12px #ffffff;
cursor: pointer;
pointer-events: none;
}
#brake-btn {
position: absolute;
bottom: calc(180px * var(--ui-scale));
right: calc(30px * var(--ui-scale));
width: calc(100px * var(--ui-scale));
height: calc(100px * var(--ui-scale));
background: rgba(0,0,0,0.5);
backdrop-filter: blur(8px);
border-radius: 50px;
border: 2px solid #ff4444;
z-index: 110;
display: none;
justify-content: center;
align-items: center;
font-family: 'Orbitron';
font-weight: bold;
color: white;
font-size: calc(20px * var(--ui-scale));
text-transform: uppercase;
pointer-events: auto;
}
#brake-btn.active { background: #ff4444; }

/* ---------- DEVICE SELECTION MODAL ---------- */
.device-modal {
position: fixed; inset: 0; background: rgba(0,0,0,0.9); backdrop-filter: blur(10px);
display: flex; align-items: center; justify-content: center; z-index: 1000;
}
.device-option { transition: all 0.2s; cursor: pointer; }
.device-option:hover { transform: scale(1.05); }

/* ---------- CYBER LEADERBOARD (Integrated) ---------- */
.leaderboard-container {
width: 350px; max-width: 40vw; font-family: 'Orbitron', sans-serif; position: absolute;
top: 20px; right: 20px; padding: 2px; z-index: 101;
background: linear-gradient(145deg, var(--accent), rgba(0,242,255,0.2) 60%, transparent 90%);
clip-path: polygon(0 18px, 18px 0, 100% 0, 100% calc(100% - 18px), calc(100% - 18px) 100%, 0 100%);
box-shadow: 0 0 35px rgba(0, 242, 255, 0.2); backdrop-filter: blur(1px);
pointer-events: none;
}
.leaderboard-container::before {
content: ""; position: absolute; top: 12px; left: 12px; width: 24px; height: 24px;
border-top: 3px solid var(--accent); border-left: 3px solid var(--accent); z-index: 6;
filter: drop-shadow(0 0 6px var(--accent));
}
.leaderboard-container::after {
content: ""; position: absolute; bottom: 12px; right: 12px; width: 24px; height: 24px;
border-bottom: 3px solid var(--accent); border-right: 3px solid var(--accent); z-index: 6;
filter: drop-shadow(0 0 6px var(--accent));
}
.leaderboard-inner {
background: var(--bg-dark); padding: 18px 12px 12px;
clip-path: polygon(0 16px, 16px 0, 100% 0, 100% calc(100% - 16px), calc(100% - 16px) 100%, 0 100%);
backdrop-filter: blur(4px);
}
.title-area {
display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 14px;
padding-bottom: 8px; border-bottom: 1px solid rgba(0, 242, 255, 0.25);
}
.title {
color: var(--accent); font-weight: 900; letter-spacing: 4px; font-size: 1rem;
display: flex; align-items: center; gap: 8px; text-shadow: 0 0 8px var(--accent);
}
.title::before {
content: ""; width: 8px; height: 8px; background: #ff0055; border-radius: 50%;
box-shadow: 0 0 12px #ff0055; animation: blink 0.9s infinite;
}
.race-info { font-size: 0.7rem; color: var(--accent); opacity: 0.9; letter-spacing: 2px; }
.fastest-lap-badge {
background: rgba(0,242,255,0.1); border: 1px solid var(--accent); padding: 3px 10px;
clip-path: polygon(4px 0, 100% 0, 100% calc(100% - 4px), calc(100% - 4px) 100%, 0 100%, 0 4px);
font-size: 0.65rem; font-weight: 600; color: #b0f0ff; white-space: nowrap;
display: inline-block; margin-bottom: 12px;
}
.board-list { max-height: 360px; overflow-y: auto; padding-right: 6px; }
.board-list::-webkit-scrollbar { width: 4px; }
.board-list::-webkit-scrollbar-track { background: #0a0f1a; }
.board-list::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 4px; }
.row {
display: flex; align-items: center; padding: 9px 10px; margin: 5px 0;
background: rgba(20, 20, 35, 0.5); border-left: 3px solid transparent;
transition: all 0.15s ease; clip-path: polygon(0 0, 100% 0, 100% calc(100% - 4px), calc(100% - 10px) 100%, 0 100%);
backdrop-filter: blur(2px); flex-wrap: wrap;
}
.row.player-highlight { background: rgba(0, 242, 255, 0.12); border-left-color: var(--accent); box-shadow: inset 0 0 15px rgba(0,242,255,0.1), var(--player-glow); }
.row.teammate-highlight { background: rgba(192, 132, 255, 0.1); border-left-color: var(--teammate); box-shadow: inset 0 0 12px rgba(192,132,255,0.1), var(--teammate-glow); }
.rank { width: 38px; font-size: 1.2rem; font-weight: 900; color: rgba(220, 240, 255, 0.4); }
.rank.gold { color: var(--gold); text-shadow: 0 0 8px gold; }
.rank.silver { color: var(--silver); text-shadow: 0 0 6px silver; }
.rank.bronze { color: var(--bronze); text-shadow: 0 0 6px #ff8c00; }
.trophy-icon { width: 26px; height: 26px; margin-right: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.trophy-icon svg { width: 22px; height: 22px; filter: drop-shadow(0 0 6px currentColor); }
.name { flex: 1; font-weight: 700; color: #f0f5ff; font-size: 0.85rem; letter-spacing: 1px; display: flex; align-items: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 80px; }
.lap-wrapper { display: flex; flex-direction: column; align-items: flex-end; min-width: 80px; }
.lap-info { font-size: 0.65rem; font-weight: 700; color: var(--accent); background: rgba(0,20,30,0.6); padding: 2px 8px; clip-path: polygon(4px 0, 100% 0, 100% calc(100% - 4px), calc(100% - 4px) 100%, 0 100%, 0 4px); border: 1px solid rgba(0,242,255,0.3); white-space: nowrap; }
.lap-progress { width: 100%; height: 4px; background: rgba(0,0,0,0.4); margin-top: 4px; clip-path: polygon(2px 0, 100% 0, 100% 100%, 0 100%, 0 2px); border: 0.5px solid rgba(0,242,255,0.3); }
.lap-progress-fill { height: 100%; background: linear-gradient(90deg, var(--accent), #a0f0ff); width: 0%; box-shadow: 0 0 6px var(--accent); transition: width 0.2s ease; }
.badge { font-size: 0.5rem; margin-left: 4px; padding: 2px 4px; background: #0a0f1f; border: 1px solid; letter-spacing: 1px; white-space: nowrap; }

/* ---------- BORDER GLOW (Enhanced) ---------- */
.glow-card { --edge-proximity:0; --cursor-angle:45deg; --edge-sensitivity:80; --color-sensitivity:calc(var(--edge-sensitivity) + 20); --border-radius:16px; --glow-padding:20px; --cone-spread:25; --fill-opacity:0.4; --glow-color:hsl(40deg 80% 80% / 100%); --glow-color-60:hsl(40deg 80% 80% / 60%); --glow-color-50:hsl(40deg 80% 80% / 50%); --glow-color-40:hsl(40deg 80% 80% / 40%); --glow-color-30:hsl(40deg 80% 80% / 30%); --glow-color-20:hsl(40deg 80% 80% / 20%); --glow-color-10:hsl(40deg 80% 80% / 10%); --gradient-one:radial-gradient(at 80% 55%, #c084fc 0px, transparent 50%); --gradient-two:radial-gradient(at 69% 34%, #f472b6 0px, transparent 50%); --gradient-three:radial-gradient(at 8% 6%, #38bdf8 0px, transparent 50%); --gradient-four:radial-gradient(at 41% 38%, #c084fc 0px, transparent 50%); --gradient-five:radial-gradient(at 86% 85%, #f472b6 0px, transparent 50%); --gradient-six:radial-gradient(at 82% 18%, #38bdf8 0px, transparent 50%); --gradient-seven:radial-gradient(at 51% 4%, #f472b6 0px, transparent 50%); --gradient-base:linear-gradient(#c084fc 0 100%); --card-bg:#0A0A0E; }
.glow-card { position:relative; border-radius:var(--border-radius); isolation:isolate; transform:translate3d(0,0,0.01px); border:1px solid rgb(255 255 255 / 15%); background:var(--card-bg); overflow:visible; box-shadow:rgba(0,0,0,0.1) 0px 1px 2px, rgba(0,0,0,0.1) 0px 2px 4px, rgba(0,0,0,0.1) 0px 4px 8px, rgba(0,0,0,0.1) 0px 8px 16px, rgba(0,0,0,0.1) 0px 16px 32px; transition:box-shadow 0.2s; }
.glow-card::before, .glow-card::after, .glow-card > .edge-light { content:""; position:absolute; inset:0; border-radius:inherit; transition:opacity 0.25s ease-out; z-index:-1; pointer-events:none; }
.glow-card:not(:hover):not(.sweep-active)::before, .glow-card:not(:hover):not(.sweep-active)::after, .glow-card:not(:hover):not(.sweep-active) > .edge-light { opacity:0; transition:opacity 0.5s; }
.glow-card::before { border:1px solid transparent; background:linear-gradient(var(--card-bg) 0 100%) padding-box, linear-gradient(rgb(255 255 255 / 0%) 0% 100%) border-box, var(--gradient-one) border-box, var(--gradient-two) border-box, var(--gradient-three) border-box, var(--gradient-four) border-box, var(--gradient-five) border-box, var(--gradient-six) border-box, var(--gradient-seven) border-box, var(--gradient-base) border-box; opacity:calc((var(--edge-proximity) - var(--color-sensitivity)) / (100 - var(--color-sensitivity))); mask-image:conic-gradient(from var(--cursor-angle) at center, black calc(var(--cone-spread)*1%), transparent calc((var(--cone-spread)+15)*1%), transparent calc((100 - var(--cone-spread)-15)*1%), black calc((100 - var(--cone-spread))*1%)); }
.glow-card::after { border:1px solid transparent; background:var(--gradient-one) padding-box, var(--gradient-two) padding-box, var(--gradient-three) padding-box, var(--gradient-four) padding-box, var(--gradient-five) padding-box, var(--gradient-six) padding-box, var(--gradient-seven) padding-box, var(--gradient-base) padding-box; mask-image:linear-gradient(to bottom, black, black), radial-gradient(ellipse at 50% 50%, black 40%, transparent 65%), radial-gradient(ellipse at 66% 66%, black 5%, transparent 40%), radial-gradient(ellipse at 33% 33%, black 5%, transparent 40%), radial-gradient(ellipse at 66% 33%, black 5%, transparent 40%), radial-gradient(ellipse at 33% 66%, black 5%, transparent 40%), conic-gradient(from var(--cursor-angle) at center, transparent 5%, black 15%, black 85%, transparent 95%); mask-composite:subtract, add, add, add, add, add; opacity:calc(var(--fill-opacity) * (var(--edge-proximity) - var(--color-sensitivity)) / (100 - var(--color-sensitivity))); mix-blend-mode:soft-light; }
.glow-card > .edge-light { inset:calc(var(--glow-padding) * -1); z-index:1; mask-image:conic-gradient(from var(--cursor-angle) at center, black 2.5%, transparent 10%, transparent 90%, black 97.5%); opacity:calc((var(--edge-proximity) - var(--edge-sensitivity)) / (100 - var(--edge-sensitivity))); mix-blend-mode:plus-lighter; }
