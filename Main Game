    getEl('driver-count-display').innerText = cars.length;
    getEl('total-laps-display').innerText = MAX_LAPS;
  }

  function checkRaceFinish() {
    if (raceFinished) return;
    if (cars.every(c => c.is_finished)) {
      raceActive = false;
      raceFinished = true;
      cancelAnimationFrame(animationFrame);
      if (countdownInterval) clearInterval(countdownInterval);
      audio.stopEngine();
      audio.playSound('crowd');
      audio.playBGM('victory');
      showPodium();
    }
  }

  function drawMiniMap() {
    if (!miniMapCtx) return;
    miniMapCtx.clearRect(0, 0, 200, 150);
    miniMapCtx.fillStyle = '#0a0a0e';
    miniMapCtx.fillRect(0, 0, 200, 150);

    let minX = Math.min(...trackPoints.map(p => p.x)), maxX = Math.max(...trackPoints.map(p => p.x));
    let minY = Math.min(...trackPoints.map(p => p.y)), maxY = Math.max(...trackPoints.map(p => p.y));
    let scaleX = 190 / (maxX - minX), scaleY = 130 / (maxY - minY);
    let scale = Math.min(scaleX, scaleY);
    let offX = (200 - (maxX - minX) * scale) / 2, offY = (150 - (maxY - minY) * scale) / 2;

    miniMapCtx.beginPath();
    miniMapCtx.strokeStyle = '#555';
    miniMapCtx.lineWidth = 3;
    miniMapCtx.moveTo((trackPoints[0].x - minX) * scale + offX, (trackPoints[0].y - minY) * scale + offY);
    for (let i = 1; i < trackPoints.length; i++) {
      miniMapCtx.lineTo((trackPoints[i].x - minX) * scale + offX, (trackPoints[i].y - minY) * scale + offY);
    }
    miniMapCtx.closePath();
    miniMapCtx.stroke();

    for (let car of cars) {
      let x = (car.x - minX) * scale + offX;
      let y = (car.y - minY) * scale + offY;
      miniMapCtx.fillStyle = car.isPlayer ? '#E10600' : '#888';
      miniMapCtx.beginPath();
      miniMapCtx.arc(x, y, 3, 0, 2 * Math.PI);
      miniMapCtx.fill();
      if (car.isPlayer) {
        miniMapCtx.strokeStyle = 'white';
        miniMapCtx.lineWidth = 1.5;
        miniMapCtx.stroke();
      }
    }
  }

  function drawScene() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    let player = cars.find(c => c.isPlayer);
    if (player) { camera.x = player.x - canvas.width/2; camera.y = player.y - canvas.height/2; }
    ctx.save(); ctx.translate(-camera.x, -camera.y);
    ctx.fillStyle = '#1a1a1a'; ctx.fillRect(camera.x-1000, camera.y-1000, canvas.width+2000, canvas.height+2000);
    ctx.beginPath(); ctx.strokeStyle = '#333'; ctx.lineWidth = 70; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
    ctx.moveTo(trackPoints[0].x, trackPoints[0].y);
    for (let i = 1; i < trackPoints.length; i++) ctx.lineTo(trackPoints[i].x, trackPoints[i].y);
    ctx.closePath(); ctx.stroke();
    ctx.beginPath(); ctx.strokeStyle = '#fff'; ctx.lineWidth = 3; ctx.setLineDash([15, 25]); ctx.stroke(); ctx.setLineDash([]);
    drawBarriers();
    let sp = trackPoints[0], sd = getDirectionAt(0), n = { x: -sd.y, y: sd.x };
    ctx.beginPath(); ctx.moveTo(sp.x + n.x*90, sp.y + n.y*90); ctx.lineTo(sp.x - n.x*90, sp.y - n.y*90);
    ctx.strokeStyle = 'white'; ctx.lineWidth = 18; ctx.stroke();
    for (let car of cars) {
      ctx.save(); ctx.translate(car.x, car.y); ctx.rotate(car.angle);
      ctx.shadowColor = 'rgba(0,0,0,0.8)'; ctx.shadowBlur = 10;
      ctx.fillStyle = car.color; ctx.fillRect(-14, -7, 28, 14);
      ctx.fillStyle = '#111'; ctx.fillRect(-7, -3, 14, 6);
      ctx.fillStyle = 'white'; ctx.font = '14px Orbitron'; ctx.fillText(car.name.substring(0,3), -14, -16);
      ctx.restore();
    }
    ctx.restore();
    fxCtx.clearRect(0, 0, fxCanvas.width, fxCanvas.height);
    if (STATE.weekend.weather && STATE.weekend.weather.type.includes('Rain')) {
      for (let i = 0; i < 6; i++) particles.push({ x: Math.random()*fxCanvas.width, y: Math.random()*fxCanvas.height, vx:2, vy:5+Math.random()*5, life:1 });
    }
    particles = particles.filter(p => { p.x += p.vx; p.y += p.vy; p.life -= 0.005; return p.life > 0 && p.y < fxCanvas.height+20; });
    fxCtx.fillStyle = 'rgba(200,200,255,0.5)';
    for (let p of particles) { fxCtx.beginPath(); fxCtx.arc(p.x, p.y, 3, 0, 2*Math.PI); fxCtx.fill(); }
    drawMiniMap();
  }

  function showPodium() {
    let sorted = [...cars].sort((a, b) => {
      if (a.is_finished !== b.is_finished) return b.is_finished - a.is_finished;
      return b.totalDistance - a.totalDistance;
    });
    let top3 = sorted.slice(0, 3);
    let playerPos = sorted.findIndex(c => c.isPlayer) + 1;
    let points = playerPos <= 10 ? F1_POINTS[playerPos - 1] : 0;
    let diffRate = STATE.weekend.difficulty === 'boy' ? 50000 : (STATE.weekend.difficulty === 'spartan' ? 75000 : 125000);
    let prize = points * diffRate;
    STATE.money += prize; updateMoney();
    const podiumDiv = getEl('podium-step'); podiumDiv.innerHTML = '';
    top3.forEach((car, idx) => {
      let medal = idx === 0 ? '🥇' : (idx === 1 ? '🥈' : '🥉');
      let color = idx === 0 ? 'text-yellow-400' : (idx === 1 ? 'text-gray-300' : 'text-amber-600');
      let celeb = car.name.includes('Cristiano') ? '🇵🇹 SIUUUU! 🇵🇹' : car.name.includes('Mbappe') ? '🇫🇷 🤨 🇫🇷' : car.name.includes('Verstappen') ? '🇳🇱 🏎️ 🇳🇱' : '🎉🎉🎉';
      podiumDiv.innerHTML += `<div class="podium-card ${idx===0?'scale-110 border-yellow-400':''}" style="background:linear-gradient(145deg, ${car.color}20, #0a0a14); border-color:${idx===0?'gold':'#aaa'}"><div class="text-4xl">${medal}</div><img src="${car.img}" class="podium-img" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\\'http://www.w3.org/2000/svg\\' width=\\'120\\' height=\\'120\\'><rect width=\\'120\\' height=\\'120\\' fill=\\'%23333\\'/><text x=\\'50%\\' y=\\'50%\\' fill=\\'%23fff\\' font-size=\\'12\\' text-anchor=\\'middle\\' dy=\\'.3em\\'>${car.name.substring(0,2)}</text></svg>'"><div class="podium-name ${color}">${car.name}</div><div>${car.team}</div><div class="text-4xl mt-2 animate-bounce">${celeb}</div></div>`;
    });
    getEl('podium-modal').style.display = 'flex';
  }

  function togglePause() { 
    playClickSound();
    racePaused = !racePaused; 
    getEl('pause-menu').style.display = racePaused ? 'flex' : 'none'; 
    if (racePaused) audio.stopEngine(); else if (STATE.weekend.mode === 'driving') audio.playEngine();
  }
  
  function retireRace() {
    playClickSound();
    raceActive = false; raceFinished = true;
    cancelAnimationFrame(animationFrame); clearInterval(countdownInterval);
    controller.deactivate();
    getEl('joystick-container').style.display = 'none';
    getEl('brake-btn').style.display = 'none';
    audio.stopEngine();
    nav('calendar');
  }

  // ----- Genie -----
  let audioCtx = null, typingOsc = null, typingGain = null, typingActive = false;
  function openGenie() {
    playClickSound();
    if (getEl('genie-modal').classList.contains('flex')) return;
    getEl('genie-modal').classList.remove('hidden'); getEl('genie-modal').classList.add('flex');
    getEl('genie-input').value = ''; getEl('genie-response').innerHTML = ''; getEl('genie-response').classList.remove('hidden');
    if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    if (typingActive) { if (typingOsc) { try { typingOsc.stop(); } catch(e){} typingOsc = null; } if (typingGain) typingGain.disconnect(); typingActive = false; }
  }
  function closeGenie() {
    playClickSound();
    getEl('genie-modal').classList.add('hidden'); getEl('genie-modal').classList.remove('flex');
    if (typingOsc) { try { typingOsc.stop(); } catch(e){} typingOsc = null; } if (typingGain) typingGain.disconnect(); typingActive = false;
  }
  function typeWriter(text, element, cb) {
    if (typingActive) return;
    typingActive = true; let i = 0; element.innerHTML = '';
    element.style.color = text.includes('Incorrect') ? '#ff3333' : '#0f0';
    element.style.textShadow = text.includes('Incorrect') ? '0 0 8px rgba(255,0,0,0.6)' : '0 0 8px rgba(0,255,0,0.6)';
    if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
    if (audioCtx) {
      typingOsc = audioCtx.createOscillator(); typingOsc.type = 'square';
      typingGain = audioCtx.createGain(); typingGain.gain.value = 0.02;
      typingOsc.connect(typingGain); typingGain.connect(audioCtx.destination); typingOsc.start();
    }
    function type() {
      if (i < text.length) {
        element.innerHTML += text.charAt(i);
        if (typingOsc) typingOsc.frequency.setValueAtTime(300 + Math.random()*200, audioCtx.currentTime);
        i++; setTimeout(type, 30 + Math.random()*40);
      } else {
        if (typingOsc) { try { typingOsc.stop(); } catch(e){} typingOsc = null; } if (typingGain) typingGain.disconnect();
        element.classList.remove('blink-cursor'); typingActive = false; if (cb) cb();
      }
    }
    type();
  }
  function checkGenieCode() {
    playClickSound();
    if (typingActive) return;
    const val = getEl('genie-input').value.toLowerCase().trim();
    const respEl = getEl('genie-response');
    if (val === 'maxgoat') {
      if (STATE.unlockedSecrets) { typeWriter('You have already claimed this power.', respEl); return; }
      STATE.unlockedSecrets = true;
      typeWriter('Access Granted. Cristiano Ronaldo and Max Verstappen Unlocked!', respEl, () => {
        setTimeout(() => { closeGenie(); nav('market', document.querySelectorAll('.nav-item')[1]); }, 2500);
      });
    } else { typeWriter('Incorrect incantation. The legends remain hidden.', respEl); }
  }

  // ----- Border Glow Initialization -----
  function initGlow() {
    document.querySelectorAll('.glow-card').forEach(card => {
      if (!card.querySelector('.edge-light')) { let e = document.createElement('span'); e.className = 'edge-light'; card.appendChild(e); }
      card.addEventListener('mousemove', e => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left, y = e.clientY - rect.top;
        const cx = rect.width/2, cy = rect.height/2;
        const dx = x - cx, dy = y - cy;
        let kx = dx !== 0 ? cx / Math.abs(dx) : Infinity;
        let ky = dy !== 0 ? cy / Math.abs(dy) : Infinity;
        const prox = Math.min(Math.max(1 / Math.min(kx, ky), 0), 1);
        const ang = (Math.atan2(dy, dx) * 180 / Math.PI + 90 + 360) % 360;
        card.style.setProperty('--edge-proximity', (prox * 100).toFixed(3));
        card.style.setProperty('--cursor-angle', ang.toFixed(3) + 'deg');
      });
      card.addEventListener('mouseleave', () => card.style.setProperty('--edge-proximity', '0'));
    });
    document.querySelectorAll('.f1-btn-primary, .f1-btn-secondary').forEach(btn => {
      btn.classList.add('glow-card', 'sweep-active');
      setTimeout(() => btn.classList.remove('sweep-active'), 3000);
    });
  }

  // ========== Final Global Exports ==========
  window.togglePause = togglePause;
  window.retireRace = retireRace;
  window.openGenie = openGenie;
  window.closeGenie = closeGenie;
  window.checkGenieCode = checkGenieCode;

  // ========== Initialization on Load ==========
  window.addEventListener('load', () => {
    renderMarket();
    renderUpgrades();
    renderCalendar();
    updateMoney();
    initGlow();
    nav('home');
  });

  // ========== PART 4 END – GAME COMPLETE ==========
})();
</script>
