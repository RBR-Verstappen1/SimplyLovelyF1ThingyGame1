        let idx = parseInt(choice) - 1;
        let old = STATE.myDrivers[idx];
        if(old.cost > 0) STATE.money += Math.floor(old.cost / 2);
        STATE.myDrivers.splice(idx, 1);
        STATE.myDrivers.push(d);
        updateMoney();
        renderMarket();
        alert(`${d.name} added!`);
        audio.playSound('click');
      }
      return;
    }
    STATE.myDrivers.push(d);
