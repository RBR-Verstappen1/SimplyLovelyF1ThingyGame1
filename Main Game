const stick = document.getElementById('joy-stick');
let isMoving = false;
const startInput = (e) => { isMoving = true; container.classList.add('active'); e.preventDefault(); };
const moveInput = (e) => {
if (!isMoving) return;
const rect = container.getBoundingClientRect();
const centerX = rect.left + rect.width/2, centerY = rect.top + rect.height/2;
const clientX = e.touches ? e.touches[0].clientX : e.clientX;
const clientY = e.touches ? e.touches[0].clientY : e.clientY;
let dx = clientX - centerX, dy = clientY - centerY;
const distance = Math.min(Math.sqrt(dx*dx+dy*dy), 45);
const angle = Math.atan2(dy, dx);
const x = Math.cos(angle)*distance, y = Math.sin(angle)*distance;
stick.style.transform = `translate(calc(-50% + ${x}px), calc(-50% + ${y}px))`;
StoryState.joystickVector = { x: x/45, y: y/45 };
if (StoryState.currentScene === 'HALL' && StoryState.useJoystick && !StoryState.inputBlocked) {
StoryState.playerPos.x += StoryState.joystickVector.x * 4;
StoryState.playerPos.y += StoryState.joystickVector.y * 4;
StoryState.playerPos.x = Math.max(20, Math.min(1000, StoryState.playerPos.x));
StoryState.playerPos.y = Math.max(20, Math.min(600, StoryState.playerPos.y));
}
};
const endInput = () => { isMoving = false; container.classList.remove('active'); stick.style.transform = 'translate(-50%, -50%)'; StoryState.joystickVector = {x:0,y:0}; };
container.addEventListener('mousedown', startInput);
window.addEventListener('mousemove', moveInput);
window.addEventListener('mouseup', endInput);
container.addEventListener('touchstart', startInput, {passive: false});
window.addEventListener('touchmove', moveInput, {passive: false});
window.addEventListener('touchend', endInput);
}

