// ========== AUDIO MANAGER (FULLY INTEGRATED) ==========
class AudioManager {
  constructor() {
    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
    this.sounds = new Map();
    this.musicGain = this.ctx.createGain();
    this.musicGain.connect(this.ctx.destination);
    this.musicGain.gain.value = 0.3;
    this.sfxGain = this.ctx.createGain();
    this.sfxGain.connect(this.ctx.destination);
    this.sfxGain.gain.value = 0.6;
    this.bgmSource = null;
    this.engineSource = null;
    this.initialized = false;
    this.muted = false;
  }

  async init() {
    if (this.initialized) return;
    if (this.ctx.state === 'suspended') await this.ctx.resume();
    await this.loadSounds();
    this.initialized = true;
  }

  async loadSounds() {
    const soundList = [
      { name: 'click', url: 'sounds/click.mp3' },
      { name: 'raceStart', url: 'sounds/race_start.mp3' },
      { name: 'engine', url: 'sounds/engine.mp3' },
      { name: 'crowd', url: 'sounds/crowd.mp3' },
      { name: 'victory', url: 'sounds/victory.mp3' }
    ];
    for (let s of soundList) {
      try {
        const response = await fetch(s.url);
        const arrayBuffer = await response.arrayBuffer();
        const audioBuffer = await this.ctx.decodeAudioData(arrayBuffer);
        this.sounds.set(s.name, audioBuffer);
      } catch (e) {
        console.warn(`Sound "${s.name}" not loaded, using fallback`);
      }
    }
  }

  playSound(name, loop = false) {
    if (this.muted || !this.initialized) return;
    const buffer = this.sounds.get(name);
    if (!buffer) {
      // Fallback: generate simple tone
      this.playFallback(name);
      return;
    }
    const source = this.ctx.createBufferSource();
    source.buffer = buffer;
    source.loop = loop;
    source.connect(this.sfxGain);
    source.start();
    return source;
  }

  playFallback(name) {
    const osc = this.ctx.createOscillator();
    const gain = this.ctx.createGain();
    osc.connect(gain);
    gain.connect(this.sfxGain);
    if (name === 'click') { osc.frequency.value = 800; gain.gain.value = 0.1; }
    else if (name === 'raceStart') { osc.frequency.value = 440; gain.gain.value = 0.15; }
    else if (name === 'engine') { osc.frequency.value = 150; gain.gain.value = 0.05; }
    else { osc.frequency.value = 600; gain.gain.value = 0.1; }
    osc.start();
    osc.stop(this.ctx.currentTime + 0.2);
  }

  playBGM(type) {
    if (this.muted) return;
    this.stopBGM();
    const buffer = this.sounds.get(type);
    if (!buffer) return;
    this.bgmSource = this.ctx.createBufferSource();
    this.bgmSource.buffer = buffer;
    this.bgmSource.loop = true;
    this.bgmSource.connect(this.musicGain);
    this.bgmSource.start();
  }

  stopBGM() {
    if (this.bgmSource) {
      try { this.bgmSource.stop(); } catch(e) {}
      this.bgmSource = null;
    }
  }

  playEngine() {
    if (this.muted) return;
    this.stopEngine();
    const buffer = this.sounds.get('engine');
    if (!buffer) return;
    this.engineSource = this.ctx.createBufferSource();
    this.engineSource.buffer = buffer;
    this.engineSource.loop = true;
    this.engineSource.connect(this.sfxGain);
    this.engineSource.start();
  }

  stopEngine() {
    if (this.engineSource) {
      try { this.engineSource.stop(); } catch(e) {}
      this.engineSource = null;
    }
  }

  async toggleMute() {
    this.muted = !this.muted;
    if (this.muted) {
      this.stopBGM();
      this.stopEngine();
    } else {
      if (STATE.currentScreen === 'race') this.playEngine();
    }
    return this.muted;
  }
}

